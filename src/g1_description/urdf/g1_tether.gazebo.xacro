  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(find g1_gazebo)/config/g1_controllers.yaml</parameters>
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
    </plugin>
  </gazebo>

  <!-- Ground-truth floating-base pose (the sim's stand-in for the real
       robot's torso IMU): publishes pelvis pose in the gazebo world frame as
       nav_msgs/Odometry on /g1/base_pose. g1_gazebo's base_tf_broadcaster.py
       turns it into the world->pelvis TF so RViz can show base attitude. -->
  <gazebo>
    <plugin name="p3d_pelvis" filename="libgazebo_ros_p3d.so">
      <ros>
        <namespace>/g1</namespace>
        <remapping>odom:=base_pose</remapping>
      </ros>
      <body_name>pelvis</body_name>
      <frame_name>world</frame_name>
      <update_rate>100</update_rate>
    </plugin>
  </gazebo>

</robot>
