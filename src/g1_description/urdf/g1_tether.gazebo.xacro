<?xml version="1.0"?>
<!--
  Gazebo Classic (11) sim overlay for the G1 tether description.

  Includes the plain kinematic/visual/collision description from
  g1_tether.urdf.xacro unchanged, then adds a ros2_control <hardware>
  binding (gazebo_ros2_control/GazeboSystem) for all 63 revolute joints
  and the gazebo_ros2_control model plugin. RViz-only usage (display.launch.py)
  does not use this file and is unaffected.

  All joints use the "position" command interface: gazebo_ros2_control's
  GazeboSystem drives it via Joint::SetPosition() (kinematic, not
  torque-based, by design; see g1_gazebo/scripts/position_bridge.py's
  header comment for why PID/effort control was dropped in favor of this).
  An earlier version used "effort" because SetPosition() didn't work here,
  but that was actually a side effect of a different bug (a disconnected SDF
  pose graph from the URDF's floating_base_joint, fixed by stripping
  world/floating_base_joint before spawning, see g1_gazebo.launch.py)
  rather than a fundamental SetPosition limitation. This also means finger
  joints move independently in sim even though only 7 motors/hand drive them
  on the real robot (see state_bridge_node.py's HAND_JOINT_NAMES comment),
  since the URDF's effort=0 limits on those 32 joints don't matter for a
  position-controlled joint.
-->
<robot name="g1_29dof_rev_1_0" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find g1_description)/urdf/g1_tether.urdf.xacro"/>

  <!-- SDF's <self_collide> defaults to false at the model level, so
       non-adjacent links (e.g. a leg swinging into the torso) pass through
       each other with no contact at all. Adjacent parent/child links along
       a joint never collide with each other regardless of this setting.
       This model is entirely position-controlled (see header comment
       above), so self_collide no longer needs to be tuned per-link to avoid
       torque chatter; overlap_monitor.py wants it true everywhere so it
       can actually detect self-overlap (including between fingers) via
       Gazebo's own contact manager. -->
  <gazebo>
    <self_collide>false</self_collide>
  </gazebo>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="left_hip_pitch_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_hip_roll_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_hip_yaw_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_knee_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_ankle_pitch_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="left_ankle_roll_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="right_hip_pitch_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="right_hip_roll_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="right_hip_yaw_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="right_knee_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="right_ankle_pitch_joint">
